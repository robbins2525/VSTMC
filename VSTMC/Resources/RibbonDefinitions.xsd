    <!-- =================================================================================
        Container Definitions
    ============================================================================== -->
    <xs:element name="BackstageItem">
        <xs:annotation>
            <xs:documentation>
                Defines an item in the Ribbon's Backstage.
            </xs:documentation>
        </xs:annotation>
        <xs:complexType>
            <xs:sequence>
                <xs:element name="Label" type="xs:string" minOccurs="0"  maxOccurs="1" />
                <xs:element name="Description" type="xs:string" minOccurs="0"  maxOccurs="1" />
                <xs:element ref="BackstageItemParams" minOccurs="0" maxOccurs="1" />
                <xs:element name="ItemContents" minOccurs="0" maxOccurs="1">
                    <xs:annotation>
                        <xs:documentation>
                            Defines the content for the BackstageItem.
                        </xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                        <xs:sequence>
                            <xs:choice minOccurs="0" maxOccurs="unbounded">
                                <xs:element ref="BackStageCommand" minOccurs="0" maxOccurs="unbounded" />
                                <xs:element ref="BackstageButtonList" minOccurs="0" maxOccurs="unbounded" />
                                <xs:element ref="BackstageGroupList" minOccurs="0" maxOccurs="unbounded" />
                                <xs:element ref="BackstageButtonListRef" minOccurs="0" maxOccurs="unbounded" />
                                <xs:element ref="BackstageGroupListRef" minOccurs="0" maxOccurs="unbounded" />
                            </xs:choice>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
            <xs:attribute name="Name" type="NameType" use="required"/>
            <xs:attribute name="Priority" type="xs:integer" use="required"/>
            <xs:attribute name="ContentType" type="BackstageItemContentType" use="required" />
            <xs:attribute name="MatchProcessing" type="DefinitionMatchProcessingType" use="optional"/>
            <xs:attribute name="IsDefault" type="xs:boolean" use="optional" >
            <xs:annotation>
                <xs:documentation>
                    Only one BackstageItem or BackstageItemRef should have IsDefault set to true. This defines the default active item when backstage is open.
                </xs:documentation>
            </xs:annotation>
            </xs:attribute>
            <xs:attribute name="CustomizationFlags" type="xs:string" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        One of the following Customization flags that can be ored together with "|".
                        None,
                        FixedButtonSize,
                        FixedKeyTip,
                        FixedPopupKeyTip,
                        FixedLabel,
                        FixedWidth,
                        ComponentContentsLocked,
                        ComponentLocked,
                        HideDefinition,
                        DisallowButtonSizeOverride,
                        DisallowGroupPinning,
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
        </xs:complexType>
    </xs:element>

    <xs:element name="BackstageGroup">
