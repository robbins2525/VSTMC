<xs:schema id="RibbonItems" xmlns="" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xs:simpleType name="DropDownContentType">
        <xs:annotation>
            <xs:documentation>
                Specifies the type of DropDown Content to be either a DropDown Panel or contain Menu Items
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="MenuItems" />
            <xs:enumeration value="PanelItems" />
            <xs:enumeration value="DgnlibBasedItems" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="GroupZoneType">
        <xs:annotation>
            <xs:documentation>
                Specifies the Position Mapping Zone that is used to determine auto-generated KeyTips. Task is the default GroupType.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Task" />
            <xs:enumeration value="Main" />
            <xs:enumeration value="Attributes" />
            <xs:enumeration value="Primary" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="DataTreeType">
        <xs:annotation>
            <xs:documentation>
                Specifies the type of XDataTreeNodes to be used to populate menu items
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Task" />
            <xs:enumeration value="NamedToolbox" />
            <xs:enumeration value="MainTask" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="DefinitionMatchProcessingType">
        <xs:annotation>
            <xs:documentation>
                Specify what to do when a definition is encountered that is already in the Definition Cache.
                Ignore   = Ignore this item, use previous definition
                Override = Override existing definition with current
                Merge    = If Contain merge contents
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Ignore" />
            <xs:enumeration value="Override" />
            <xs:enumeration value="Merge" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="ReferenceMatchProcessingType">
        <xs:annotation>
            <xs:documentation>
                Specify what to do when a reference to an existing definition is encountered.
                Ignore = Ignore this item, use previous definition
                Remove =  Remove the item from the cache, which means that the item will not be available to add to any Ribbon.
                Override = Override existing sort priority and access text in matching definition or reference
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Ignore" />
            <xs:enumeration value="Remove" />
            <xs:enumeration value="Override" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="BackstageItemContentType">
        <xs:annotation>
            <xs:documentation>
                BackStageCommand    = Content that defines a command to execute.
                BackstageButtonList = Content that contain a list of groups.
                BackstageGroupList  = Content that contain a list of buttons.
                Separator           = Draws separator in between items.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="BackStageCommand" />
            <xs:enumeration value="BackstageButtonList" />
            <xs:enumeration value="BackstageGroupList" />
            <xs:enumeration value="Separator" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="DropDownPanelType">
        <xs:annotation>
            <xs:documentation>
                VerticalStacked    = panel that stacks items vertically
                HorizontalStacked  = panel that stacks items horizontally.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="VerticalStacked" />
            <xs:enumeration value="HorizontalStacked" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="GroupPanelType">
        <xs:annotation>
            <xs:documentation>
                VerticalStacked    = panel that stacks items vertically (using this type will inhibit the ability to override size by group).
                HorizontalStacked  = panel that stacks items horizontally (using this type will inhibit the ability to override size by group).
                Collapsible        = panel that allows contained buttons to be resized or collapsed.
                OrderedWrap        = panel that wraps items into a max of 3 rows. This panel also resizes it contained buttons as necessary.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="VerticalStacked" />
            <xs:enumeration value="HorizontalStacked" />
            <xs:enumeration value="Collapsible" />
            <xs:enumeration value="OrderedWrap" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="VerticalAlignmentType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Top" />
            <xs:enumeration value="Bottom" />
            <xs:enumeration value="Center" />
            <xs:enumeration value="Stretch" />
        </xs:restriction>
    </xs:simpleType>
    
    <xs:simpleType name="HorizontalAlignmentType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Left" />
            <xs:enumeration value="Right" />
            <xs:enumeration value="Center" />
            <xs:enumeration value="Stretch" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="IconRscType">
        <xs:annotation>
            <xs:documentation>
                SmallOrLarge = 0,
                Bitmap = 1114207309,
                SmallOrLargeBitmap = 1114919756,
                Custom = 1231253358,
                WindowsIcon = 1464427374,
                Large = 1766018151,
                Small = 1766019949,
                IconPopup = 1766879088,
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="SmallOrLarge" />
            <xs:enumeration value="Bitmap" />
            <xs:enumeration value="SmallOrLargeBitmap" />
            <xs:enumeration value="Custom" />
            <xs:enumeration value="WindowsIcon" />
            <xs:enumeration value="Large" />
            <xs:enumeration value="Small" />
            <xs:enumeration value="IconPopup" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="IconType">
        <xs:annotation>
            <xs:documentation>
                NamedIcon - specifies look-up name for icon
                RscIcon   - specifies RscType, Id, and owner
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="NamedIcon" />
            <xs:enumeration value="RscIcon" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="CollapseThresholdType">
        <xs:annotation>
            <xs:documentation>
                Specifiy button resize options based on group size.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Never" />
            <xs:enumeration value="WhenGroupIsMedium" />
            <xs:enumeration value="WhenGroupIsSmall" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="ButtonSizeType">
        <xs:annotation>
            <xs:documentation>
                Specifiy button size.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="Small" />
            <xs:enumeration value="Medium" />
            <xs:enumeration value="Large" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="NameType">
        <xs:annotation>
            <xs:documentation>
                Specifiy name of a ribbon component. Characters limited to a-z A-Z 0-9_.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:pattern value="[_.a-zA-Z0-9\-]+" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="ResizePriority">
        <xs:annotation>
            <xs:documentation>
                Specifiy priority used by ribbon to determine the order of group resizing.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:integer">
            <xs:minInclusive value="0" />
            <xs:maxInclusive value="10000" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="CommandType">
        <xs:annotation>
            <xs:documentation>
                Specifiy the type of command. NamedCommand(XCommand), ApplicationRefCommand(Iconcmd), or UserKeyinCommand size.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:string">
            <xs:enumeration value="NamedCommand" />
            <xs:enumeration value="ApplicationRefCommand" />
            <xs:enumeration value="UserKeyinCommand" />
        </xs:restriction>
    </xs:simpleType>

    <xs:element name="ApplicationParams">
        <xs:complexType>
        <xs:sequence>
            <xs:element name="ApplicationParam" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="Name" type="xs:string" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="Value" type="xs:string" minOccurs="1" maxOccurs="1"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    </xs:element>

    <xs:element name="ApplicationItemsKeyTips">
        <xs:annotation>
            <xs:documentation>
                Specifiy a collection of Key Tips for items contained in an application provided container like a Tab or a Group.
            </xs:documentation>
        </xs:annotation>

        <xs:complexType>
            <xs:sequence>
                <xs:element name="ApplicationItem" minOccurs="0" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="AccessText" type="xs:string" minOccurs="1" maxOccurs="1"/>
                            <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" maxOccurs="1"/>
                            <xs:element name="GroupLauncherAccessText" type="xs:string" minOccurs="0" maxOccurs="1"/>
                        </xs:sequence>
                        <xs:attribute name="Name" type="NameType" use="required"/>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
    

    <xs:element name="Visibility">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="ShowExpression" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
                <xs:element name="FeatureAspect" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
            </xs:sequence>
            <xs:attribute name="HiddenByDefault" type="xs:boolean"  use="optional"/>
        </xs:complexType>
    </xs:element>

    <xs:complexType name="Icon">
        <xs:sequence>
            <xs:choice>
                <xs:element name="NamedIcon" type="xs:string" minOccurs="0" maxOccurs="1"/>
                <xs:element name="RscIcon" minOccurs="0" maxOccurs="1">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="RscType" type="IconRscType" minOccurs="0" maxOccurs="1"/>
                            <xs:element name="RscId" type="xs:integer" minOccurs="0" maxOccurs="1"/>
                            <xs:element name="TaskId" type="xs:string" minOccurs="0" maxOccurs="1"/>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:choice>
        </xs:sequence>
        <xs:attribute name="Type" type="IconType" />
    </xs:complexType>

    <xs:element name="Icon">
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="Icon"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>

    <xs:element name="UserKeyinCommand">
        <xs:complexType>
            <xs:choice minOccurs="1" maxOccurs="unbounded">
                <xs:element name="Label" type="xs:string" minOccurs="0" />
                <xs:element name="Description" type="xs:string" minOccurs="0" />
                <xs:element name="Keyin" type="xs:string" minOccurs="1" maxOccurs="1"/>
                <xs:element ref="Icon" minOccurs="0" maxOccurs="1" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element name="EnableExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
                <xs:element name="ToggleExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
                <xs:element name="MenuMarkExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
            </xs:choice>
        </xs:complexType>
    </xs:element>

    
    <xs:element name="ApplicationRefCommand">
        <xs:complexType>
            <xs:choice minOccurs="1" maxOccurs="unbounded">
                <xs:element name="Label" type="xs:string" minOccurs="0" />
                <xs:element name="Description" type="xs:string" minOccurs="0" />
                <xs:element name="TaskId" type="xs:string" minOccurs="0" maxOccurs="1"/>
                <xs:element name="CmdNumber" type="xs:unsignedLong" minOccurs="0" maxOccurs="1"/>
                <xs:element name="CmdParameters" type="xs:string" minOccurs="0" maxOccurs="1"/>
                <xs:element ref="Icon" minOccurs="0" maxOccurs="1" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element name="EnableExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
                <xs:element name="ToggleExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
                <xs:element name="MenuMarkExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
            </xs:choice>
        </xs:complexType>
    </xs:element>
    
    <xs:element name="CheckedIcon">
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="Icon"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>
    
    <xs:element name="UncheckedIcon">
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="Icon"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>

    <xs:element name="DisabledIcon">
        <xs:complexType>
            <xs:complexContent>
                <xs:extension base="Icon"/>
            </xs:complexContent>
        </xs:complexType>
    </xs:element>

    <!-- =================================================================================
        Parameters
    ============================================================================== -->

    <xs:element name="TabSetParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
            </xs:choice>
        </xs:complexType>
    </xs:element>

    <xs:element name="WorkflowParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
            </xs:choice>
        </xs:complexType>
    </xs:element>

    <xs:element name="BackstageGroupParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
            </xs:choice>
        </xs:complexType>
    </xs:element>

    <xs:element name="GroupPanelParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
            </xs:choice>
            <xs:attribute name="AddSeparatorBefore" type="xs:boolean" use="optional">
                <xs:annotation>
                    <xs:documentation>
                        This option is only ensured to work if the panel is a root panel directly in a ribbon group. A separator will not be shown if this is the first panel in a group.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
        </xs:complexType>
    </xs:element>

    <xs:element name="TabParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="unbounded"/>
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
                <xs:element ref="ApplicationItemsKeyTips" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
        </xs:complexType>
    </xs:element>

    <xs:element name="RibbonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="Label" type="xs:string" minOccurs="0" />
                <xs:element name="Description" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="unbounded"/>
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
        </xs:complexType>
    </xs:element>

    <xs:element name="DropDownButtonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element name="EnableExpression" type="xs:string"  minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" />
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" />
        </xs:complexType>
    </xs:element>

    <xs:element name="ToggleButtonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" />
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" />
            <xs:attribute name="ShowLabelOnly" type="xs:boolean" use="optional" />
        </xs:complexType>
    </xs:element>

    <xs:element name="GalleryParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Width" type="xs:integer"  use="optional"/>
        </xs:complexType>
    </xs:element>

    <xs:element name="RadioButtonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" />
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" />
        </xs:complexType>
    </xs:element>
    
    <xs:element name="SplitButtonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" />
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" />
        </xs:complexType>
    </xs:element>

    <xs:element name="ComboBoxParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0"  maxOccurs="1" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Width" type="xs:string" />
        </xs:complexType>
    </xs:element>

    <xs:element name="ButtonParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0"  maxOccurs="1" />
                <xs:element name="PopupAccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" />
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" />
        </xs:complexType>
    </xs:element>

    <xs:element name="AutoSizingRules">
        <xs:complexType>
            <xs:attribute name="Size" type="ButtonSizeType" />
            <xs:attribute name="CollapseToSmall" type="CollapseThresholdType" use="optional"/>
            <xs:attribute name="CollapseToMedium" type="CollapseThresholdType" use="optional"/>
            <xs:attribute name="NumAdditionalLargeSets" type="xs:integer" use="optional"/>
            <xs:attribute name="NumMediumSets" type="xs:integer" use="optional"/>
        </xs:complexType>
    </xs:element>

    <xs:element name="GroupParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0"  maxOccurs="1" />
                <xs:element name="GroupLauncherAccessText" type="xs:string" minOccurs="0" maxOccurs="1"/>
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="AutoSizingRules" minOccurs="0" maxOccurs="1"/>
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
                <xs:element ref="ApplicationItemsKeyTips" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="CollapsePriority" type="ResizePriority" />
            <xs:attribute name="SmallPriority" type="ResizePriority" />
            <xs:attribute name="MediumPriority" type="ResizePriority" />
            <xs:attribute name="LargePriority" type="ResizePriority" />
            <xs:attribute name="AlwaysShowCollapsed" type="xs:boolean" use="optional"/>
        </xs:complexType>
    </xs:element>

    <xs:element name="MenuItemParams">
        <xs:complexType>
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="AccessText" type="xs:string" minOccurs="0" />
                <xs:element name="SyncItemEvent" type="xs:string" minOccurs="0" maxOccurs="1" />
                <xs:element ref="Visibility" minOccurs="0" maxOccurs="1" />
                <xs:element ref="ApplicationParams" minOccurs="0" maxOccurs="1"/>
            </xs:choice>
            <xs:attribute name="ShowCmdIcon" type="xs:boolean" />
            <xs:attribute name="UseMenuMarkImage" type="xs:boolean" />
            <xs:attribute name="UpdateParentSplitButtonIfChecked" type="xs:boolean" />  <!-- If item CheckState is set to true, and is a child of a Split Button, refresh the split button. -->
        </xs:complexType>
    </xs:element>

